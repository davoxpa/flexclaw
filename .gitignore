# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# File ambiente e segreti locali
.env
.env.local
.env.*.local
!.env.example

# Dati runtime: ignora i contenuti ma mantieni la struttura delle cartelle via .gitkeep
data/**
!data/**/
!data/**/.gitkeep

# File generati nella sandbox
sandbox/*
!sandbox/.gitkeep

# macOS
.DS_Store

# Configurazioni locali dei plugin (contengono dati personali)
plugin/**/config.yaml
