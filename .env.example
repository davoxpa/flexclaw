# ATTENZIONE: Non versionare mai le chiavi reali in git!
# In produzione usa un vault (es. HashiCorp Vault, AWS Secrets Manager, Doppler, ecc.)
# oppure variabili d'ambiente gestite dal sistema di deploy.

# ──  — Variabili d'ambiente ─────────────────────────────────────────
# Copia questo file in .env e inserisci le tue chiavi API.
#   cp .env.example .env

# ── API Keys (inserisci almeno la chiave del provider configurato) ───────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=

# ── Configurazione App ──────────────────────────────────────────────────────
APP_ENV=production
AGENT_OS_PORT=7777
